<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp2.MainPage">

    <ScrollView>
        <StackLayout>
            <Label Text="Personal Goal Progress App"
                   FontSize="20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <Entry x:Name="goalName"
                   Placeholder="Descirption" 
                   Margin="10"/>
            <Entry x:Name="goalEndDate"
                   Placeholder="End date YYYY-MM-DD" 
                   Margin="10"/>
            <Button x:Name="addGoal" 
                    Text="Add"
                    Clicked="OnAddGoalClicked"
                    Margin="10"/>
            <Button x:Name="deleteGoal" 
                    Text="Delete"
                Clicked="OnDeleteGoalClicked" 
                    Margin="10"/>

            <CollectionView x:Name="goalsCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate >
                        <VerticalStackLayout 
                            Padding="10">
                            <Grid ColumnDefinitions="Auto"
                                  RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto" HorizontalOptions="Center" >
                                <Grid.Triggers>
                                    <DataTrigger TargetType="Grid"
                                                 Binding="{Binding IsDone}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor" Value="DarkGreen" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Grid"
                                                  Binding="{Binding IsDone}"
                                                  Value="False">     
                                        <Setter Property="BackgroundColor" Value="DarkBlue" />
                                    </DataTrigger>
                                </Grid.Triggers>
                                <Label Grid.Row="0" 
                                       Text="{Binding Title}" 
                                       HorizontalOptions="Center"/>
                                <Label Grid.Row="1" 
                                       Text="{Binding StartOn, StringFormat='Start: {0:dd-MM-yyyy}'}" 
                                       HorizontalOptions="Center"/>
                                <Label Grid.Row="2" 
                                       Text="{Binding EndOn, StringFormat='End: {0:dd-MM-yyyy}'}" 
                                       HorizontalOptions="Center"/>
                                <Label Grid.Row="3"
                                    x:Name="goalProgressText"
                                    Text="{Binding ProgressPercentage, StringFormat='Progress: {0}%'}" 
                                    HorizontalOptions="Center"/>
                                <ProgressBar Grid.Row="4"
                                    x:Name="goalProgress"
                                    Progress="{Binding Progress}"
                                    ProgressColor="Green"
                                    BackgroundColor="#EEEEEE"
                                    HeightRequest="12"
                                    Margin="10" />
                                <Label Grid.Row="5" 
                                    Text="{Binding DaysAfterStart, StringFormat='Started {0} days ago'}" 
                                    HorizontalOptions="Center"/>
                                <Label Grid.Row="6" 
                                    Text="{Binding DaysLeftToEnd, StringFormat='Ends in {0} days'}" 
                                    HorizontalOptions="Center"/>
                            </Grid>

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ScrollView>

</ContentPage>
